{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacks": {
      "language": "python",
      "pythonVersion": "3.11",
      "startFile": "start.sh",
      "installCommand": "pip install -r requirements.txt --no-cache-dir 2>&1 | tail -5"
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "sleepPeriod": "1s",
    "healthCheckPath": "/health",
    "port": 10000
  }
}